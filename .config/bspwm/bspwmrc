#! /bin/sh

shopt -s huponexit

bspc config border_width		2
bspc config window_gap			5
bspc config top_padding			12
bspc config bottom_padding		-5
bspc config left_padding		-5
bspc config right_padding		-5
bspc config split_ratio			0.50
bspc config focus_follows_pointer	true
bspc config auto_alternate		true
bspc config auto_cancel			true
bspc config history_aware_focus		true
bspc config focused_border_color	'#0087af'
bspc config urgent_border_color		'#5f0000'

bspc monitor -d 1 2 3 4 5 6 7 8 9 0

~/bin/bspwm-bar | lemonbar -g 500x15 -u 0 -f 'envypn:size=6' | sh &
xtitle -s -f "%%{r}%%{F#ff303030}%%{F-}%%{B#ff303030}%%{F#ff9e9e9e}%s%%{B-}%%{F-}" | lemonbar -g 1374x15+500 -u 0 -f 'envypn:size=6' &

xsetroot -cursor_name left_ptr
xrdb -merge .Xresources
setxkbmap hr

sh ~/.fehbg &

sxhkd &
clip-share :0 :1 &
