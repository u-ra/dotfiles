#! /bin/sh

shopt -s huponexit

bspc config border_width		2
bspc config window_gap			5
bspc config top_padding			12
bspc config bottom_padding		-5
bspc config left_padding		-5
bspc config right_padding		-5
bspc config split_ratio			0.50
bspc config focus_follows_pointer	true
bspc config history_aware_focus		true
bspc config focused_border_color	'#b8bb26'

bspc monitor -d 1 2 3 4 5 6 7 8 9 0

half_res=$(($(xrandr | head -1 | awk '{print $8}')/2))
height=16
font="Fantasque Sans Mono:size=11"

~/bin/bbar | lemonbar -g ${half_res}x${height} -u 0 -f "$font" | sh &

title_fg="#ff282828"
title_bg="#ffba8baf"

xtitle -s -f "%%{r}%%{F${title_bg}}%%{F-}%%{B${title_bg}}%%{F${title_fg}}%s%%{B-}%%{F-}" | \
lemonbar -g ${half_res}x${height}+${half_res} -u 0 -f "$font" &

xsetroot -cursor_name left_ptr
xrdb -merge .Xresources
setxkbmap hr

sh ~/.fehbg &

sxhkd &
clip-share :0 :1 &
