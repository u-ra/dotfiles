#
# bspwm hotkeys
#

# Exit BSPWM
alt +shift + e
    pkill conky; pkill panel; pkill bspwm-bar; bspc quit

# Close current window
alt + shift + q
    bspc node -c

# Cycle desktop layouts tiled | monocle (fullscreen)
alt + t
    bspc desktop -l next

# Balance desktop
alt + b
    bspc node @focused:/ -B

# Toggle floating
alt + shift + space
    bspc node -t ~floating

# Rotate windows CW 90 degrees
alt + Tab
    bspc node @focused:/ -R 90

# Rotate windows CCW 90 degrees
alt + shift + Tab
    bspc node @focused:/ -R -90

# Move window into a presel
alt + grave
    bspc node -n last.!automatic

# Swap current window with the biggest
alt + m
    bspc node -s biggest

# Focus/Move around
alt + {_,shift + }{Left,Down,Up,Right}
    bspc node -{f,s} {west,south,north,east}

# Create a presel
alt + ctrl + {Left,Down,Up,Right}
    dir={west,south,north,east}; \
    cur=$(bspc query -T -n focused.!automatic | jshon -e presel -e splitDir -u 2>&-); \
    [ "$dir" = "$cur" ] && dir=cancel; \
    bspc node -p "$dir"

# Go to desktop
#alt + {1-9,0}
#    item="^{1-9,10}"; \
#
alt + {1-9,0}
    item="{1-9,0}"; \
    bspc query --desktops --desktop "$\{item\}.focused" > /dev/null && item=last; \
    bspc desktop -f "$item"

# Move to desktop
alt + shift + {1-9,0}
    bspc node -d {1-9,0}

#
# wm independent hotkeys
#
XF86MonBrightnessDown
    xbacklight -dec 5

XF86MonBrightnessUp
    xbacklight -inc 5

alt + Return
    qterminal

shift + Print
    scrot

super + m
    amixer set Master toggle

super + Left
    mpc prev

super + Right
    mpc next

super + l
    /home/jura/bin/screenlock.sh

alt + d
    rofi -show run

alt + s
    rofi -show ssh

# make sxhkd reload its configuration files:
alt + Escape
    pkill -USR1 -x sxhkd
