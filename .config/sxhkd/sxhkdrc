#
# bspwm hotkeys
#

# Exit BSPWM
alt +shift + e
    pkill conky; pkill panel; pkill bspwm-bar; bspc quit

# Close current window
alt + shift + q
    bspc node -c

# Cycle desktop layouts tiled | monocle (fullscreen)
alt + t
    bspc desktop -l next

# Balance desktop
alt + b
    bspc node @focused:/ -B

# Toggle floating
alt + shift + space
    bspc node -t ~floating

# Rotate windows 90 degrees
alt + Tab
    bspc node @focused:/ -R 90

# Move window into a presel
alt + grave
    bspc node -n last.!automatic

# Swap current window with the biggest
alt + m
    bspc node -s biggest

# Focus/Move around
alt + {_,shift + }{Left,Down,Up,Right}
    bspc node -{f,s} {west,south,north,east}

# Create a presel
alt + ctrl + {Left,Down,Up,Right}
    dir={west,south,north,east}; \
    cur=$(bspc query -T -n focused.!automatic | jshon -e presel -e splitDir -u 2>&-); \
    [ "$dir" = "$cur" ] && dir=cancel; \
    bspc node -p "$dir"

# Go to desktop
alt + {1-9,0}
    item="^{1-9,10}"; \
    bspc query --desktops --desktop "$\{item\}.focused" > /dev/null && item=last; \
    bspc desktop -f "$item"

# Move to desktop
alt + shift + {1-9,0}
    bspc node -d {1-9,0}

~button1
    bspc pointer -g focus

alt + button{1-3}
    bspc pointer -g {move,resize_side,resize_corner}

alt + !button{1-3}
    bspc pointer -t %i %i

alt + @button{1-3}
    bspc pointer -u

#
# wm independent hotkeys
#
alt + Return
    termite

shift + Print
    scrot

super + m
    amixer set Master toggle

alt + d
    rofi -bg '#272822' -hlbg '#0087af' -bc '#0087af' -bw 2 -fg '#f8f8f2' -hlfg '#FFFFFF' -font 'envypn 13' -width 15 -terminal termite -show run -pid /tmp/rofi.pid

# make sxhkd reload its configuration files:
alt + Escape
    pkill -USR1 -x sxhkd
