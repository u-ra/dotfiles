[settings]
; Limit the amount of events sent to lemonbar within a set timeframe:
; - "Allow <throttle_limit> updates within <throttle_ms> of time"
; Default values:
;throttle_limit = 5
;throttle_ms = 50

[bar/bar]
bottom = false
dock = false

width = 100%
height = 16

background = #181818
foreground = #fff
linecolor = #ffffff

spacing = 1
lineheight = 0

padding_left = 0
padding_right = 0
module_margin_left = 0
module_margin_right = 0

font-0 = NotoSans:pixelsize=11;0
font-1 = FontAwesome:size=9:weight=heavy;0

modules-left = bspwm xtitle
modules-center =
modules-right = mpd volume cpu ram battery clock

[module/battery]
type = internal/battery
full_at = 99
battery = BAT0
adapter = AC
format-charging = <animation-charging> <label-charging>
format-discharging = <ramp-capacity> <label-discharging>
ramp-capacity-0 = ’ēä
ramp-capacity-1 = ’ēā
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ
bar-capacity-width = 10
animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
animation-charging-framerate_ms = 750
format-charging-padding = 2
format-charging-foreground = #7cafc2

[module/mpd]
type = internal/mpd
host = 127.0.0.1
port = 6600
format-online = ’Ćü  <label-song>  <toggle> <icon-prev> <icon-next>  <icon-random>
format-offline = <label-offline>
format-offline-offset = -8

; By only specifying alpha value, it will be applied to the bar's default foreground
;label-time-foreground = #66
label-offline = mpd is off
;label-offline-foreground = #66

icon-play = ’üŗ
icon-pause = ’üī
icon-random = ’ü┤
icon-next = ’üæ
icon-prev = ’üł

[module/xtitle]
type = custom/script
exec = xtitle -s
tail = true

[module/cpu]
