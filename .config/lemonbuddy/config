[settings]
; Limit the amount of events sent to lemonbar within a set timeframe:
; - "Allow <throttle_limit> updates within <throttle_ms> of time"
; Default values:
;throttle_limit = 5
;throttle_ms = 50

[bar/bar]
bottom = false
dock = false

width = 100%
height = 16

background = #181818
foreground = #fff
linecolor = #ffffff

spacing = 1
lineheight = 0

;separator = Ō¢ō

;locale = en_US.UTF-8

padding_left = 0
padding_right = 0
module_margin_left = 0
module_margin_right = 0

font-0 = NotoSans:size=8;0
font-1 = FontAwesome:size=9:weight=heavy;0

modules-left = bspwm
modules-center = xtitle
modules-right = volume cpu ram battery clock

[module/battery]
type = internal/battery
full_at = 99
battery = BAT0
adapter = AC
format-charging = <animation-charging> <label-charging>
format-discharging = <ramp-capacity> <label-discharging>
ramp-capacity-0 = ’ēä
ramp-capacity-1 = ’ēā
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ
bar-capacity-width = 10
animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
animation-charging-framerate_ms = 750
format-charging-padding = 2
format-charging-background = #7cafc2
format-charging-foreground = #181818

[module/xtitle]
type = custom/script
exec = xtitle -s
tail = true

[module/cpu]
type = internal/cpu
label = ’éģ %percentage%
format-background = #a1b56c
format-foreground = #181818
format-padding = 2

[module/ram]
type = internal/memory
label = ’é« %percentage_used%
format-background = #f7ca88
format-foreground = #181818
format-padding = 2

[module/clock]
type = internal/date
format = ’ĆŚ  <date>
date = %Y-%m-%d %H:%M
format-background = #ab4642
format-foreground = #181818
format-padding = 2

[module/volume]
type = internal/volume

format-volume-background = #ba8baf
format-volume-foreground = #181818
format-volume-padding = 2
format-muted-background = #ba8baf
format-muted-foreground = #181818
format-muted-padding = 2

label-volume = ’Ć© %percentage%
label-muted = Sound is muted

[module/bspwm]
type = internal/bspwm
label-urgent = ’åÆ
label-urgent-background = #7cafc2
label-urgent-foreground = #af2031
label-active = ’äæ
label-active-background = #7cafc2
label-active-padding = 1
label-occupied = ’åÆ
label-occupied-background = #7cafc2
label-occupied-padding = 1
label-empty = ’ćø
label-empty-background = #7cafc2
label-empty-padding = 1

