[settings]
; Limit the amount of events sent to lemonbar within a set timeframe:
; - "Allow <throttle_limit> updates within <throttle_ms> of time"
; Default values:
;throttle_limit = 5
;throttle_ms = 50

color-00  =  #263238
color-01  =  #ec5f67
color-02  =  #8bd649
color-03  =  #ffcc00
color-04  =  #89ddff
color-05  =  #82aaff
color-06  =  #80cbc4
color-07  =  #cdd3de
color-08  =  #707880
color-09  =  #ec5f67
color-10  =  #8bd649
color-11  =  #ffcc00
color-12  =  #89ddff
color-13  =  #82aaff
color-14  =  #80cbc4
color-15  =  #ffffff
color-16  =  #ea9560
color-17  =  #ec5f67
color-18  =  #2c393f
color-19  =  #37474f
color-20  =  #c9ccd3
color-21  =  #d5dbe5

font-0 = NotoSansUI:pixelsize=11;0
font-1 = MaterialIcons:pixelsize=14:weight=heavy;0

[bar/main]
bottom = false
dock = false
monitor = eDP1
width = 100%
height = 16
background = ${settings.color-00}
foreground = ${settings.color-07}
spacing = 1
underline-size = 0
overline-size = 0
padding_left = 0
padding_right = 0
module_margin_left = 1
module_margin_right = 1
font-0 = NotoSansUI:pixelsize=11;0
font-1 = MaterialIcons:pixelsize=14:weight=heavy;0
modules-left = bspwm
modules-center =
modules-right = mpd wireless-network wired-network backlight volume cpu ram battery clock
tray-position = right
locale = hr_HR.UTF-8

[bar/ext]
bottom = false
dock = false
monitor = HDMI1
width = 100%
height = 16
background = ${settings.color-00}
foreground = ${settings.color-07}
spacing = 1
underline-size = 0
overline-size = 0
padding_left = 0
padding_right = 0
module_margin_left = 1
module_margin_right = 1
font-0 = NotoSansUI:pixelsize=11;0
font-1 = MaterialIcons:pixelsize=14:weight=heavy;0
modules-left = bspwm
modules-center =
modules-right = mpd wireless-network wired-network volume cpu ram battery clock
locale = hr_HR.UTF-8

[module/bspwm]
type = internal/bspwm
label-urgent = 
label-urgent-foreground = ${settings.color-17}
label-active = 
label-active-foreground = ${settings.color-04}
label-occupied = 
label-empty = 

[module/mpd]
type = internal/mpd
host = 127.0.0.1
port = 6600
format-online =  <label-song> <toggle> <icon-prev> <icon-next>
format-online-foreground = ${settings.color-21}
format-offline =   <label-offline>
format-offline-foreground = ${settings.color-21}
label-offline = Off
icon-play = 
icon-pause = 
icon-next = 
icon-prev = 

[module/wireless-network]
type = internal/network
interface = wlp2s0
format-connected = <label-connected>
format-connected-foreground = ${settings.color-05}
label-connected =  %essid% %signal% %local_ip%
format-disconnected = <label-disconnected>
format-disconnected-foreground = ${settings.color-05}
label-disconnected =  Disconnected

[module/wired-network]
type = internal/network
interface = enp3s0
format-connected = <label-connected>
format-connected-foreground = ${settings.color-05}
label-connected =  %linkspeed% %local_ip%
format-disconnected = <label-disconnected>
format-disconnected-foreground = ${settings.color-05}
label-disconnected =  Disconnected

[module/backlight]
type = internal/backlight
card = intel_backlight
format = <ramp> <label>
format-foreground = ${settings.color-16}
ramp-0 = 
ramp-1 = 
ramp-2 = 
label = %percentage%

[module/volume]
type = internal/volume
format-volume = <label-volume>
format-volume-foreground = ${settings.color-16}
label-volume =  %percentage%
format-muted = <label-muted>
label-muted =  Muted

[module/cpu]
type = internal/cpu
format = <label>
format-foreground = ${settings.color-16}
label =  %percentage%

[module/ram]
type = internal/memory
format = <label>
format-foreground = ${settings.color-16}
label =  %percentage_used%

[module/battery]
type = internal/battery
full_at = 99
battery = BAT1
adapter = ACAD
format-charging = <label-charging>
format-charging-foreground = ${settings.color-16}
label-charging =  %percentage%
format-discharging = <label-discharging>
format-discharging-foreground = ${settings.color-16}
label-discharging =  %percentage%
format-full = <label-full>
format-full-foreground = ${settings.color-16}
label-full =  %percentage%

[module/clock]
type = internal/date
format =   <date>
format-foreground = ${settings.color-05}
date = %c

; vim:ft=dosini
